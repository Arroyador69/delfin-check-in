# =====================================================
# VARIABLES DE ENTORNO PARA SISTEMA DE RESERVAS DIRECTAS
# =====================================================

# Stripe Configuration (ya existentes)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Nuevas variables para reservas directas
# =====================================================

# Configuración de comisiones
DELFIN_COMMISSION_RATE=0.0900  # 9% de comisión por defecto
STRIPE_FEE_RATE=0.0140         # 1.4% de Stripe + 0.25€ fijo
MINIMUM_COMMISSION=1.00        # Comisión mínima en euros

# Configuración de pagos
STRIPE_CURRENCY=eur            # Moneda por defecto
STRIPE_PAYMENT_METHODS=card    # Métodos de pago permitidos
PAYMENT_TIMEOUT_MINUTES=30     # Timeout para completar pago

# Configuración de reservas
MINIMUM_NIGHTS_DEFAULT=1       # Noches mínimas por defecto
MAXIMUM_NIGHTS_DEFAULT=30      # Noches máximas por defecto
ADVANCE_BOOKING_DAYS=365       # Días de antelación para reservar
CANCELLATION_HOURS=24          # Horas antes del check-in para cancelar

# Configuración de notificaciones
EMAIL_RESERVATION_CONFIRMATION=true
EMAIL_PROPERTY_OWNER_NOTIFICATION=true
SMS_RESERVATION_CONFIRMATION=false

# Configuración de imágenes
MAX_PHOTOS_PER_PROPERTY=20
MAX_PHOTO_SIZE_MB=5
ALLOWED_PHOTO_FORMATS=jpg,jpeg,png,webp

# Configuración de SEO
SEO_BASE_URL=https://delfincheckin.com/book
SEO_PROPERTY_SLUG_FORMAT=property-name-location

# Configuración de analytics
GOOGLE_ANALYTICS_ID=G-...
FACEBOOK_PIXEL_ID=...

# Configuración de caché
CACHE_RESERVATION_DATA=true
CACHE_PROPERTY_DATA=true
CACHE_DURATION_HOURS=1

# Configuración de límites
MAX_RESERVATIONS_PER_DAY=100
MAX_GUESTS_PER_PROPERTY=20
MAX_PROPERTIES_PER_TENANT=50

# Configuración de seguridad
RATE_LIMIT_RESERVATIONS_PER_HOUR=10
RATE_LIMIT_PAYMENT_ATTEMPTS_PER_HOUR=5
BLOCK_SUSPICIOUS_IPS=true

# Configuración de integración MIR
AUTO_SEND_MIR_DIRECT_RESERVATIONS=true
MIR_GUEST_TYPE_DIRECT_RESERVATION=DIRECT

# Configuración de webhooks
STRIPE_WEBHOOK_ENDPOINT=/api/stripe/webhook
RESERVATION_WEBHOOK_ENDPOINT=/api/webhooks/reservation

# Configuración de desarrollo
NODE_ENV=development
DEBUG_DIRECT_RESERVATIONS=true
MOCK_PAYMENTS=false




