{
  "functions": {
    "src/app/guest-registration/page.tsx": {
      "maxDuration": 30
    },
    "src/app/reservations-form/page.tsx": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/guest-registration",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/reservations-form",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "public": true,
  "github": {
    "silent": true
  }
}
