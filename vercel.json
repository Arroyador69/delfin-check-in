{
  "headers": [
    {
      "source": "/api/public/guest-registration",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://form.delfincheckin.com"
        },
        {
          "key": "Vary",
          "value": "Origin"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Accept"
        },
        {
          "key": "Access-Control-Max-Age",
          "value": "86400"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "functions": {
    "src/app/guest-registration/page.tsx": {
      "maxDuration": 30
    },
    "src/app/reservations-form/page.tsx": {
      "maxDuration": 30
    }
  },
  "github": {
    "silent": true
  }
}
