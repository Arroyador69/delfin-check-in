# ===========================================
# DELFÍN CHECK-IN - VARIABLES DE ENTORNO
# ===========================================
# 
# Copia este archivo como .env.local y rellena con tus valores reales
# NUNCA subas .env.local al repositorio - contiene datos sensibles
#

# ===========================================
# BASE DE DATOS - NEON
# ===========================================
# URL de conexión a PostgreSQL en Neon
POSTGRES_URL="postgresql://usuario:password@ep-xxxxx.neon.tech/database"
POSTGRES_PRISMA_URL="postgresql://usuario:password@ep-xxxxx.neon.tech/database?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://usuario:password@ep-xxxxx.neon.tech/database"

# ===========================================
# AUTENTICACIÓN Y SEGURIDAD 🔐
# ===========================================

# Hash bcrypt de la contraseña de administrador (12 rounds)
# ⚠️ NO almacenar contraseñas en texto plano
# Para generar: npx ts-node scripts/generate-hash.ts <tu_contraseña>
ADMIN_SECRET_HASH="$2a$12$example_bcrypt_hash_here_replace_with_real_hash"

# Secreto para firmar tokens JWT (64+ caracteres aleatorios)
# ⚠️ Este valor NUNCA debe ser compartido ni expuesto
# Para generar: npx ts-node scripts/generate-hash.ts <tu_contraseña>
JWT_SECRET="your_random_64_character_jwt_secret_here_replace_with_generated_value"

# Solo si usas POST/GET /api/emergency-restore-tenant (requiere cabecera x-emergency-restore-secret).
# Sin esta variable, la ruta responde 404.
# EMERGENCY_RESTORE_SECRET="genera_un_valor_largo_aleatorio"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚠️  VARIABLES DEPRECADAS (ya no usar):
# - ADMIN_SECRET (reemplazado por ADMIN_SECRET_HASH)
# - ADMIN_PASSWORD (eliminado, ahora se usa solo ADMIN_SECRET_HASH)
# - NEXTAUTH_SECRET (no se usa NextAuth, se usa JWT custom)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# URL base de tu aplicación
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# REDIS/KV (para caché y sesiones)
# ===========================================
# Vercel KV o Redis externo
KV_URL="redis://default:password@host:port"
KV_REST_API_URL="https://tu-kv-host/rest"
KV_REST_API_TOKEN="tu-token-kv"
KV_REST_API_READ_ONLY_TOKEN="tu-token-readonly"

# ===========================================
# NEON DATABASE (configuración adicional si necesitas)
# ===========================================
# Estas variables se configuran automáticamente en Neon
# NEON_DATABASE_URL="postgresql://usuario:password@ep-xxxxx.neon.tech/database"
# NEON_POOLED_CONNECTION_STRING="postgresql://usuario:password@ep-xxxxx.neon.tech/database?pgbouncer=true"

# ===========================================
# TELEGRAM (notificaciones)
# ===========================================
TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
TELEGRAM_CHAT_ID="-1001234567890"

# ===========================================
# CONFIGURACIÓN DEL ESTABLECIMIENTO
# ===========================================
# Código del establecimiento para el Ministerio
ESTABLISHMENT_CODE="0000256653"

# Nombre del establecimiento
ESTABLISHMENT_NAME="Delfín Check-in"

# ===========================================
# URLS EXTERNAS
# ===========================================
# API externa para datos de propiedades (si usas)
EXTERNAL_PROPERTY_API_URL="https://api.tu-proveedor.com"
EXTERNAL_PROPERTY_API_KEY="tu-api-key"

# ===========================================
# DESARROLLO LOCAL
# ===========================================
# Puerto del servidor de desarrollo
PORT=3000

# Nivel de logs (debug, info, warn, error)
LOG_LEVEL="info"

# Modo de desarrollo
NODE_ENV="development"

# ===========================================
# PAGOS - STRIPE (Connect para reservas y links) 💳
# ===========================================
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook para reservas directas (si mantienes el endpoint actual)
STRIPE_WEBHOOK_DIRECT_RESERVATIONS_SECRET="whsec_..."

# ===========================================
# SUSCRIPCIONES - POLAR (MoR para SaaS) 🧾
# ===========================================
# Crear token en Polar y configúralo aquí:
POLAR_ACCESS_TOKEN="polar_pat_..."

# Secreto del endpoint de webhook en Polar:
POLAR_WEBHOOK_SECRET="whsec_..."

# sandbox | production
POLAR_SERVER="sandbox"

# URL de éxito (Polar reemplaza {CHECKOUT_ID})
POLAR_SUCCESS_URL="http://localhost:3000/es/settings/billing?polar=success&checkout_id={CHECKOUT_ID}"

# URL de retorno (botón "Volver" en checkout)
POLAR_RETURN_URL="http://localhost:3000"

# IDs de producto en Polar (para checkout MoR de "Mejorar plan")
# Mensual (month)
POLAR_PRODUCT_CHECKIN_ID="prod_..."
POLAR_PRODUCT_STANDARD_ID="prod_..."
POLAR_PRODUCT_PRO_ID="prod_..."

# Anual (year) - recomendado: precio anual = 10 meses (2 meses de descuento)
POLAR_PRODUCT_CHECKIN_YEARLY_ID="prod_..."
POLAR_PRODUCT_STANDARD_YEARLY_ID="prod_..."
POLAR_PRODUCT_PRO_YEARLY_ID="prod_..."

# Nota: el +2 €/unidad adicional se configura en Polar como pricing seat-based.

# Plan Básico: producto seat-based para cobrar solo unidades extra (2 €/mes por unidad adicional).
POLAR_PRODUCT_FREE_EXTRA_UNITS_ID="prod_..."
# Plan Básico anual: unidades extra (20 €/año por unidad adicional, equivalente a 2 €/mes con 2 meses gratis).
POLAR_PRODUCT_FREE_EXTRA_UNITS_YEARLY_ID="prod_..."

# ===========================================
# ANÁLISIS Y MONITOREO
# ===========================================
# Google Analytics (opcional)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Sentry para monitoreo de errores (opcional)
SENTRY_DSN="https://tu-dsn@sentry.io/proyecto"

# ===========================================
# CONFIGURACIÓN DE EMAIL (opcional)
# ===========================================
# Para envío de emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu-email@gmail.com"
SMTP_PASS="tu-password-app"

