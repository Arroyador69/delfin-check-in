# Ministerio del Interior (Servicio de Comunicación PV)
# URLs oficiales del MIR:
# Pruebas: https://hospedajes.pre-ses.mir.es/hospedajes-web/ws/v1/comunicacion
# Producción: https://hospedajes.ses.mir.es/hospedajes-web/ws/v1/comunicacion
MIR_BASE_URL=https://hospedajes.pre-ses.mir.es/hospedajes-web/ws/v1/comunicacion
MIR_HTTP_USER=tu_usuario_mir_aqui
MIR_HTTP_PASS=tu_contraseña_mir_aqui
MIR_CODIGO_ARRENDADOR=tu_codigo_arrendador_aqui
MIR_APLICACION=Delfin_Check_in
# false para envío REAL al MIR. true solo para pruebas locales
MIR_SIMULACION=false
# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password_here

# Stripe Configuration (optional)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔐 AUTENTICACIÓN Y SEGURIDAD
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Hash bcrypt de la contraseña de administrador (generado con bcrypt, 12 rounds)
# ⚠️ NO almacenar contraseñas en texto plano
# Para generar: npx ts-node scripts/generate-hash.ts <tu_contraseña>
ADMIN_SECRET_HASH=$2a$12$example_bcrypt_hash_here_replace_with_real_hash

# Secreto para firmar tokens JWT (64+ caracteres aleatorios)
# ⚠️ Este valor NUNCA debe ser compartido ni expuesto
# Para generar: npx ts-node scripts/generate-hash.ts <tu_contraseña>
JWT_SECRET=your_random_64_character_jwt_secret_here_replace_with_generated_value

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚠️  VARIABLES DEPRECADAS (ya no usar):
# - ADMIN_SECRET (reemplazado por ADMIN_SECRET_HASH)
# - ADMIN_PASSWORD (eliminado, ahora se usa solo ADMIN_SECRET_HASH)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
