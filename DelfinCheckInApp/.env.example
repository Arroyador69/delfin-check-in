# Copia a .env y ajusta. En EAS: eas secret:create --name EXPO_PUBLIC_...

# AdMob — iOS (perfil Delfín Check-in en AdMob)
# App ID (debe coincidir exactamente con AdMob; suele terminar en ~4354523068)
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-6039298229774115~4354523068
# Un intersticial por app: si creaste varios bloques, usa solo uno aquí (p. ej. /7074688196)
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL_ID=ca-app-pub-6039298229774115/7074688196
# Cuando crees el bloque banner en AdMob (iOS):
# EXPO_PUBLIC_ADMOB_IOS_BANNER_ID=ca-app-pub-6039298229774115/XXXXXXXX

# AdMob — Android (cuando exista la app en AdMob / Play)
# EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-XXXX~YYYY
# EXPO_PUBLIC_ADMOB_ANDROID_BANNER_ID=ca-app-pub-XXXX/ZZZZ
# EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL_ID=ca-app-pub-XXXX/WWWW
