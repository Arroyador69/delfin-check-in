    "@stripe/stripe-js": "^8.0.0",
    "@vercel/kv": "^1.0.0",
    "@vercel/postgres": "^0.10.0",
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.540.0",
    "next": "15.4.6",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.11",
    "openai": "^4.75.0",
    "react": "^18",
    "react-dom": "^18",
    "stripe": "^18.5.0",
    "tailwind-merge": "^2.0.0",
    "telegram-bot-api": "^2.0.1",
    "xmlbuilder2": "^3.1.1",
